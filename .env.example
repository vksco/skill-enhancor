# skill-enhancer env var inventory.
# Copy to .env (NEVER commit .env). Run `skillenhance config` for guided setup.
#
# Validation order: loadEnv() in src/env.ts reads these. Missing required vars
# for the chosen provider fail at module load with an actionable message.

# ─── Per-provider API keys (required) ─────────────────────────────────────────
# Anthropic (default provider; set this first)
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# Minimax (OpenAI-compatible endpoint — also requires MINIMAX_BASE_URL)
MINIMAX_API_KEY=

# Custom OpenAI-compatible endpoint — requires CUSTOM_BASE_URL + CUSTOM_API_KEY
CUSTOM_API_KEY=

# ─── Per-provider model overrides (optional, defaults in src/env.ts) ─────────
# ANTHROPIC_MODEL=claude-sonnet-5
# OPENAI_MODEL=gpt-5
# GOOGLE_MODEL=gemini-2.5-pro
# MINIMAX_MODEL=MiniMax-M3
# CUSTOM_MODEL=

# ─── Per-provider base URLs ──────────────────────────────────────────────────
# Minimax — verify with vendor before uncommenting.
# MINIMAX_BASE_URL=https://api.minimax.com/v1

# Custom endpoint
# CUSTOM_BASE_URL=

# ─── Phase 1 spike only ──────────────────────────────────────────────────────
# Override the model used by `npm run spike`. Never read by production commands.
# SPIKE_MODEL=claude-haiku-4-5-20251001

# ─── Loop tuning (post-Phase 4) ───────────────────────────────────────────────
# SKILL_ENHANCE_ROUNDS=10
# SKILL_ENHANCE_STAGNATION=3
# SKILL_ENHANCE_MASTERY_COMPOSITE=9.5
# SKILL_ENHANCE_MASTERY_AXIS=9.0
# SKILL_ENHANCE_TOKEN_CEILING=2000000
