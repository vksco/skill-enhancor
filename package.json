{
  "name": "skill-enhancer",
  "version": "0.1.0",
  "description": "Windows CLI that enhances Claude skills via autoresearch-style iteration. See SPEC.md.",
  "type": "module",
  "bin": {
    "skillenhance": "./dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "spike": "tsx src/spike.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "skillenhance": "node --import tsx src/cli.ts"
  },
  "dependencies": {
    "ai": "^7.0.31",
    "@ai-sdk/anthropic": "^4.0.16",
    "@ai-sdk/openai": "^4.0.16",
    "@ai-sdk/openai-compatible": "^3.0.12",
    "@inquirer/prompts": "^8.5.2",
    "dotenv": "^17.4.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "files": [
    "dist",
    "README.md",
    "SPEC.md"
  ]
}
